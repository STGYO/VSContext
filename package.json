{
  "name": "vscontext",
  "displayName": "VSContext",
  "description": "A stable VS Code extension for workspace symbol graphing, execution tracing, and impact analysis.",
  "version": "0.1.4",
  "publisher": "ShriSrimoyTrivedy",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/STGYO/VSContext"
  },
  "bugs": {
    "url": "https://github.com/STGYO/VSContext/issues"
  },
  "homepage": "https://github.com/STGYO/VSContext",
  "galleryBanner": {
    "color": "#1E293B",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "call graph",
    "execution trace",
    "impact analysis",
    "code navigation"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscontextExplorer",
          "title": "VSContext",
          "icon": "resources/activity-bar.svg"
        }
      ]
    },
    "views": {
      "vscontextExplorer": [
        {
          "id": "vscontext.explorer",
          "name": "VSContext"
        }
      ]
    },
    "commands": [
      {
        "command": "vscontext.traceExecution",
        "title": "Trace Path",
        "category": "VSContext",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "vscontext.findImpact",
        "title": "Impact",
        "category": "VSContext",
        "icon": "$(git-compare)"
      },
      {
        "command": "vscontext.viewCodeGraph",
        "title": "View Code Graph",
        "category": "VSContext",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscontext.traceExecution",
          "when": "view == vscontext.explorer",
          "group": "navigation@1"
        },
        {
          "command": "vscontext.findImpact",
          "when": "view == vscontext.explorer",
          "group": "navigation@2"
        },
        {
          "command": "vscontext.viewCodeGraph",
          "when": "view == vscontext.explorer",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "VSContext",
      "properties": {
        "vscontext.maxScannedFiles": {
          "type": "number",
          "default": 5000,
          "minimum": 100,
          "description": "DEPRECATED: use vscontext.maxIndexedFiles instead."
        },
        "vscontext.maxIndexedFiles": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "description": "Maximum number of workspace source files scanned for indexing."
        },
        "vscontext.refreshDebounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "description": "Debounce interval for graph refresh after workspace file changes."
        },
        "vscontext.workerBatchSize": {
          "type": "number",
          "default": 75,
          "minimum": 50,
          "maximum": 100,
          "description": "Batch size used by VSContext worker pre-scan tasks."
        },
        "vscontext.workerCount": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum number of worker threads used for VSContext pre-scan processing."
        },
        "vscontext.debugSymbolDetection": {
          "type": "boolean",
          "default": true,
          "description": "Enable verbose symbol extraction, graph node creation, and tree node creation diagnostics in the VSContext output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "files": [
    "out",
    "webview",
    "node_modules/cytoscape/dist/cytoscape.min.js",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "icon.png",
    "icon.svg",
    "resources/activity-bar.svg"
  ],
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.9.3",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "cytoscape": "^3.31.2",
    "tree-sitter": "0.21.1",
    "tree-sitter-c": "0.21.4",
    "tree-sitter-cpp": "0.22.3",
    "tree-sitter-go": "0.21.0",
    "tree-sitter-java": "0.21.0",
    "tree-sitter-javascript": "0.21.0",
    "tree-sitter-python": "0.21.0",
    "tree-sitter-rust": "0.21.0",
    "tree-sitter-typescript": "0.23.2"
  }
}
